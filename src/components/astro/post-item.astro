---
import { formatDate } from "~/utils"

interface PostData {
  title: string
  pubDate: Date
  description?: string
}

interface Post {
  id: string
  data: PostData
}

interface Props {
  post: Post
  lang: string
  dateFormat?: string
  compact?: boolean
}

const { post, lang, dateFormat = "default", compact = false } = Astro.props

// Validate required props
if (!post?.id || !post?.data?.title || !post?.data?.pubDate) {
  throw new Error("PostItem: Invalid post data provided")
}

if (!lang || typeof lang !== "string") {
  throw new Error("PostItem: Valid language (lang) is required")
}

// Generate post URL
const postUrl = `/${lang}/posts/${post.id}/`

// Format the publication date
const formattedDate = formatDate(
  post.data.pubDate,
  lang,
  dateFormat === "default" ? undefined : dateFormat,
)
const datetime = post.data.pubDate.toISOString()
---

<article
  class:list={[
    "flex w-full items-baseline gap-x-4",
    compact
      ? "py-0.5"
      : "align-center my-3 flex-row-reverse justify-end gap-x-6 md:my-2",
  ]}
>
  <h3 class:list={[compact ? "text-base" : "text-lg", "hover:underline"]}>
    <a
      href={postUrl}
      class="visited:text-purple-500/90"
      title={post.data.title}
      aria-label={`Read post: ${post.data.title}`}
    >
      {post.data.title}
    </a>
  </h3>
  <time
    class:list={[
      "shrink-0 text-right text-gray-500 dark:text-gray-400",
      compact ? "text-xs" : "text-gray-700 dark:text-white/80",
    ]}
    datetime={datetime}
    aria-label={`Published on ${formattedDate}`}
  >
    {formattedDate}
  </time>
</article>
